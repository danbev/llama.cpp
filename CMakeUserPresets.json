    },
    {
      "name": "win-cuda-89-reldbg",
      "configurePreset": "win-cuda-89-reldbg",
      "inherits": "base-build"
    },
    {
      "name": "win-cpu-debug",
      "configurePreset": "win-cpu-debug",
      "inherits": "base-build"
    },
    {
      "name": "win-cpu-release",
      "configurePreset": "win-cpu-release",
      "inherits": "base-build"
    },
    {
      "name": "win-clang-debug",
      "configurePreset": "win-clang-debug",
