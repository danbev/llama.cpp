{
  "version": 6,
  "configurePresets": [
    {
      "name": "danbev-cpu-base",
      "hidden": true,
      "inherits": "base",
      "description": "Common flags for all my CPU builds",
      "generator": "Ninja",
      "cacheVariables": {
        "GGML_NATIVE": "ON",
        "LLAMA_BUILD_TESTS": "ON",
        "LLAMA_BUILD_EXAMPLES": "ON",
        "LLAMA_BUILD_SERVER": "ON",
        "LLAMA_BUILD_BORINGSSL": "ON"
      }
    },
    {
      "name": "cpu-debug",
      "displayName": "Local CPU Debug build",
      "inherits": ["danbev-cpu-base", "debug"]
    },
    {
      "name": "cpu-release",
      "displayName": "Local CPU Release build",
      "inherits": ["danbev-cpu-base", "release"]
    },
    {
      "name": "danbev-cuda-base",
      "hidden": true,
      "inherits": "base",
      "description": "Common flags for all my CUDA builds",
      "generator": "Ninja",
      "cacheVariables": {
        "GGML_CUDA": "ON",
        "GGML_CPU_AARCH64": "OFF",
        "GGML_CUDA_F16": "ON",
        "GGML_NATIVE": "ON",
        "LLAMA_BUILD_TESTS": "ON",
        "LLAMA_BUILD_EXAMPLES": "ON",
        "LLAMA_BUILD_BORINGSSL": "ON"
      }
    },
    {
      "name": "cuda-89-debug",
      "displayName": "Local RTX 4070 (Arch 89)",
      "inherits": ["danbev-cuda-base", "debug"],
      "cacheVariables": {
        "CMAKE_CUDA_ARCHITECTURES": "89",
        "GGML_CUDA_DEBUG": "OFF",
        "CMAKE_CUDA_FLAGS": "-G -g"
      }
    },
    {
      "name": "cuda-89-release",
      "displayName": "Local RTX 4070 (Arch 89) Release",
      "inherits": ["danbev-cuda-base", "release"],
      "cacheVariables": {
        "CMAKE_CUDA_ARCHITECTURES": "89"
      }
    },
    {
      "name": "cuda-89-reldbg",
      "displayName": "Local RTX 4070 (Arch 89) RelWithDebInfo",
      "inherits": ["danbev-cuda-base", "reldbg"],
      "cacheVariables": {
        "CMAKE_CUDA_ARCHITECTURES": "89",
        "CMAKE_CUDA_FLAGS": "-g"
      }
    },
    {
      "name": "dgx-spark-debug",
      "displayName": "DGX Spark Debug",
      "inherits": ["danbev-cuda-base", "debug"],
      "description": "Standard debug build for DGX, auto-detects arch",
      "cacheVariables": {
        "GGML_NATIVE": "ON"
      }
    },
    {
      "name": "dgx-spark-release",
      "displayName": "DGX Spark Release",
      "inherits": ["danbev-cuda-base", "release"],
      "description": "Standard release build for DGX, auto-detects arch",
      "cacheVariables": {
        "GGML_NATIVE": "ON"
      }
    },
    {
      "name": "danbev-hip-base",
      "hidden": true,
      "inherits": "base",
      "description": "Common flags for all my HIP/ROCm builds",
      "generator": "Ninja",
      "environment": {
        "HIPCXX": "/opt/rocm-7.1.0/lib/llvm/bin/clang++",
        "HIP_PATH": "/opt/rocm-7.1.0"
      },
      "cacheVariables": {
        "GGML_HIP": "ON",
        "CMAKE_PREFIX_PATH": "/opt/rocm-7.1.0",
        "GGML_NATIVE": "ON",
        "LLAMA_BUILD_TESTS": "ON",
        "LLAMA_BUILD_EXAMPLES": "ON",
        "LLAMA_BUILD_BORINGSSL": "ON"
      }
    },
    {
      "name": "hip-gfx1151-debug",
      "displayName": "HIP gfx1151 Debug",
      "inherits": ["danbev-hip-base", "debug"],
      "cacheVariables": {
        "AMDGPU_TARGETS": "gfx1151"
      }
    },
    {
      "name": "hip-gfx1151-release",
      "displayName": "HIP gfx1151 Release",
      "inherits": ["danbev-hip-base", "release"],
      "cacheVariables": {
        "AMDGPU_TARGETS": "gfx1151"
      }
    },
    {
      "name": "win-cuda-89-debug",
      "displayName": "Windows RTX 4070 (Arch 89) Debug",
      "inherits": ["danbev-cuda-base", "debug"],
      "cacheVariables": {
        "CMAKE_CUDA_ARCHITECTURES": "89",
        "GGML_CUDA_DEBUG": "OFF",
        "CMAKE_CUDA_FLAGS": "-G -g"
      }
    },
    {
      "name": "win-cuda-89-release",
      "displayName": "Windows RTX 4070 (Arch 89) Release",
      "inherits": ["danbev-cuda-base", "release"],
      "cacheVariables": {
        "CMAKE_CUDA_ARCHITECTURES": "89"
      }
    },
    {
      "name": "win-cuda-89-reldbg",
      "displayName": "Windows RTX 4070 (Arch 89) RelWithDebInfo",
      "inherits": ["danbev-cuda-base", "reldbg"],
      "cacheVariables": {
        "CMAKE_CUDA_ARCHITECTURES": "89",
        "CMAKE_CUDA_FLAGS": "-g"
      }
    },
    {
      "name": "danbev-win-cpu-base",
      "hidden": true,
      "inherits": "base",
      "description": "Common flags for all my Windows CPU builds",
      "generator": "Ninja",
      "cacheVariables": {
        "LLAMA_BUILD_TESTS": "ON",
        "LLAMA_BUILD_EXAMPLES": "ON",
        "LLAMA_BUILD_SERVER": "ON",
        "LLAMA_BUILD_BORINGSSL": "ON",
        "LLAMA_LLGUIDANCE": "ON"
      }
    },
    {
      "name": "win-cpu-debug",
      "displayName": "Windows CPU Debug build",
      "inherits": ["danbev-win-cpu-base", "debug"]
    },
    {
      "name": "win-cpu-release",
      "displayName": "Windows CPU Release build",
      "inherits": ["danbev-win-cpu-base", "release"]
    },
    {
      "name": "win-clang-debug",
      "displayName": "Windows Clang Debug",
      "inherits": ["base", "x64-windows-llvm", "debug"],
      "cacheVariables": {
        "LLAMA_BUILD_TESTS": "ON",
        "LLAMA_BUILD_EXAMPLES": "ON",
        "LLAMA_BUILD_SERVER": "ON"
      }
    },
    {
      "name": "win-clang-release",
      "displayName": "Windows Clang Release",
      "inherits": ["base", "x64-windows-llvm", "release"],
      "cacheVariables": {
        "LLAMA_BUILD_TESTS": "ON",
        "LLAMA_BUILD_EXAMPLES": "ON",
        "LLAMA_BUILD_SERVER": "ON"
      }
    },
    {
      "name": "danbev-webgpu-base",
      "hidden": true,
      "inherits": "base",
      "description": "Common flags for all my WebGPU builds",
      "generator": "Ninja",
      "cacheVariables": {
        "GGML_WEBGPU": "ON",
        "GGML_METAL": "OFF",
        "GGML_BLAS": "OFF",
        "LLAMA_BUILD_TESTS": "ON",
        "LLAMA_BUILD_EXAMPLES": "ON"
      }
    },
    {
      "name": "webgpu-debug",
      "displayName": "WebGPU Debug",
      "inherits": ["danbev-webgpu-base", "debug"],
      "description": "WebGPU debug build with Dawn"
    },
    {
      "name": "webgpu-release",
      "displayName": "WebGPU Release",
      "inherits": ["danbev-webgpu-base", "release"],
      "description": "WebGPU release build with Dawn"
    }
  ],
  "buildPresets": [
    {
      "name": "base-build",
      "hidden": true,
      "jobs": 12
    },
    {
      "name": "cpu-debug",
      "configurePreset": "cpu-debug",
      "inherits": "base-build"
    },
    {
      "name": "cpu-release",
